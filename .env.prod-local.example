# Copy to .env.prod-local for a local prod-like Docker run.
# Values here are intentionally local-only and safe to keep boring.

TZ=Asia/Irkutsk
OTZIV_APP_BASE_URL=http://localhost:8088
KEYCLOAK_PUBLIC_URL=http://localhost:8088/keycloak
LOCAL_MYSQL_PORT=3307
LOCAL_MYSQL_VOLUME=otziv-prod-local_mysql_data

APP_IMAGE=otziv-app:prod-local
WEB_IMAGE=otziv-web:prod-local

MYSQL_ROOT_PASSWORD=local-root-password
DATABASE_URL=jdbc:mysql://mysql:3306/otziv?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=Asia/Irkutsk
MYSQL_DATABASE=otziv
MYSQL_USER=hunt
MYSQL_PASSWORD=local-mysql-password

KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=local-keycloak-db-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_REALM=otziv
KEYCLOAK_ADMIN_CLIENT_ID=otziv-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-local-secret
KEYCLOAK_AUDIENCE=otziv-backend
KEYCLOAK_ISSUER_URI=http://localhost:8088/keycloak/realms/otziv
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/keycloak/realms/otziv/protocol/openid-connect/certs
KEYCLOAK_ADMIN_SERVER_URL=http://keycloak:8080/keycloak
KC_PROXY_TRUSTED_ADDRESSES=172.16.0.0/12,127.0.0.0/8

SESSION_TIMEOUT=30m
JAVA_OPTS=-Xms256m -Xmx768m -XX:MaxRAMPercentage=75
OTZIV_LOG_PATH=/app/logs
OTZIV_CABINET_CACHE_TTL=PT3H
OTZIV_LEGACY_ENABLED=false
OTZIV_BOARD_LIVE_SLICE_RETENTION_DAYS=90
OTZIV_ARCHIVE_ORDERS_RETENTION_DAYS=60
OTZIV_ARCHIVE_ORDERS_BATCH_SIZE=500
OTZIV_ARCHIVE_ORDERS_MAX_BATCH_SIZE=5000
OTZIV_ARCHIVE_ORDERS_APPLY_ENABLED=false
OTZIV_ARCHIVE_ORDERS_SCHEDULE_ENABLED=false
OTZIV_ARCHIVE_ORDERS_SCHEDULE_CRON="0 15 4 * * *"
OTZIV_ARCHIVE_ORDERS_SCHEDULE_ZONE=Asia/Irkutsk
OTZIV_ANALYTICS_AGGREGATES_READ_ENABLED=false
OTZIV_ANALYTICS_REBUILD_API_ENABLED=false
OTZIV_ANALYTICS_REBUILD_STARTUP_ENABLED=false
OTZIV_ANALYTICS_REBUILD_STARTUP_MONTH=
OTZIV_ANALYTICS_REBUILD_STARTUP_CLOSED=false
OTZIV_ANALYTICS_REBUILD_SCHEDULE_ENABLED=false
OTZIV_ANALYTICS_REBUILD_SCHEDULE_CRON="0 30 3 * * *"
OTZIV_ANALYTICS_REBUILD_SCHEDULE_ZONE=Asia/Irkutsk
OTZIV_ANALYTICS_REBUILD_SCHEDULE_PREVIOUS_MONTH_WINDOW_DAYS=7
OTZIV_ANALYTICS_REBUILD_SCHEDULE_VERIFY_ADMIN_MONTH=true
OTZIV_SLOW_SQL_MS=50
OTZIV_HIBERNATE_STATISTICS=false

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=local
MAIL_PASSWORD=local
MAIL_STARTTLS_ENABLE=false

TELEGRAM_BOT_TOKEN=local-dev-token
TELEGRAM_BOT_USERNAME=local-dev-bot

S3_ACCESS_KEY=local
S3_SECRET_KEY=local-minio-secret
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=http://localhost:9001/local
S3_REGION=us-east-1
S3_BUCKET=local
S3_PROJECT=local

OPENAI_API_KEY=local-dev-key
OPENAI_PROXY_HOST=
OPENAI_PROXY_PORT=8888

JWT_SECRET=local-dev-secret-local-dev-secret-local-dev-secret-local-dev-secret

LEAD_TRANSFER_URL=http://localhost:8088/api/leads/import
LEAD_SYNCHRONY_URL=http://localhost:8088/api/leads/modified
LEAD_UPDATE_URL=http://localhost:8088/api/leads/update
LEAD_VPS_URL=http://localhost:8088/api/leads/sync
LEAD_SYNC_OUTBOUND_ENABLED=false
LEAD_VPS_RETRY_BATCH_SIZE=100
LEAD_VPS_RETRY_MAX_ATTEMPTS=20
LEAD_VPS_RETRY_PERIOD_MS=1800000

APP_NAGUL_COOLDOWN=60
MULTIBROWSER_BASE_URL=http://multi-browser:3000

BACKUP_ENABLED=false
BACKUP_WORK_DIR=/app/backup
BACKUP_MYSQL_HOST=mysql
BACKUP_MYSQL_PORT=3306
BACKUP_MYSQL_DUMP_BINARY=mysqldump
BACKUP_PART_SIZE_MB=35
BACKUP_MAIL_TO=local@example.test
BACKUP_MAIL_FROM=local@example.test
BACKUP_MAIL_SUBJECT=Otziv local database backup
BACKUP_MAIL_BODY=Local database backup

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
