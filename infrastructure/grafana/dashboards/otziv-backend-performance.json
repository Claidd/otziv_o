{
  "uid": "otziv-backend-performance",
  "title": "Otziv Backend: производительность и логи",
  "tags": ["otziv", "backend", "performance", "logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "label": "Раздел",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(otziv_endpoint_duration_seconds_count, endpoint)",
        "query": {
          "query": "label_values(otziv_endpoint_duration_seconds_count, endpoint)",
          "refId": "EndpointVariable"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "Все",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Backend: состояние",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(up{job=~\"app|app-local\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "СБОЙ", "color": "red" },
                "1": { "text": "ОК", "color": "green" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Запросы в секунду",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ошибки в секунду",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\",result=\"error\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Максимум P95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(histogram_quantile(0.95, sum(rate(otziv_endpoint_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval])) by (le, endpoint)))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Максимум P99",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(histogram_quantile(0.99, sum(rate(otziv_endpoint_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval])) by (le, endpoint)))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "P95 задержки по разделам",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(otziv_endpoint_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval])) by (le, endpoint)) and on(endpoint) sum(rate(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\"}[$__rate_interval])) by (endpoint) > 0",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "P99 задержки по разделам",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(otziv_endpoint_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__rate_interval])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Средняя задержка по разделам",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(otziv_endpoint_duration_seconds_sum{endpoint=~\"$endpoint\"}[$__rate_interval])) by (endpoint) / sum(rate(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\"}[$__rate_interval])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Запросы в секунду по разделам и результату",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\"}[$__rate_interval])) by (endpoint, result)",
          "legendFormat": "{{endpoint}} {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Запросы за выбранный период",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\"}[$__range])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16
      },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Самые медленные разделы",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(otziv_endpoint_duration_seconds_bucket{endpoint=~\"$endpoint\"}[$__range])) by (le, endpoint)) and on(endpoint) sum(increase(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\"}[$__range])) by (endpoint) > 0",
          "format": "table",
          "instant": true,
          "refId": "P95"
        },
        {
          "expr": "sum(increase(otziv_endpoint_duration_seconds_count{endpoint=~\"$endpoint\"}[$__range])) by (endpoint)",
          "format": "table",
          "instant": true,
          "refId": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #P95"
            },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #RPS"
            },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        }
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "endpoint",
            "mode": "inner"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time #P95": true,
              "Time #RPS": true,
              "Time 1": true,
              "Time 2": true
            },
            "indexByName": {
              "endpoint": 0,
              "Value #P95": 1,
              "Value #RPS": 2
            },
            "renameByName": {
              "endpoint": "Раздел",
              "Value #P95": "P95",
              "Value #RPS": "Запросы"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "P95",
                "desc": true
              }
            ]
          }
        }
      ],
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Cache hit/miss в секунду",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(cache_gets_total{cache=~\"cabinet.*\", result=~\"hit|miss\"}[$__rate_interval])) by (cache, result)",
          "legendFormat": "{{cache}} {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 }
    },
    {
      "id": 17,
      "type": "bargauge",
      "title": "Cache hit-rate за период",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "100 * sum(increase(cache_gets_total{cache=~\"cabinet.*\", result=\"hit\"}[$__range])) by (cache) / sum(increase(cache_gets_total{cache=~\"cabinet.*\"}[$__range])) by (cache)",
          "legendFormat": "{{cache}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16
      },
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 }
    },
    {
      "id": 18,
      "type": "bargauge",
      "title": "Cache miss за период",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "round(sum(increase(cache_gets_total{cache=~\"cabinet.*\", result=\"miss\"}[$__range])) by (cache))",
          "legendFormat": "{{cache}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16
      },
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 }
    },
    {
      "id": 19,
      "type": "bargauge",
      "title": "Размер cache",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "cache_size{cache=~\"cabinet.*\"}",
