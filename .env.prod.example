# Copy to .env.prod on the VPS and replace every CHANGE_ME value.

TZ=Asia/Irkutsk
DOMAIN=o-ogo.ru
CERTBOT_EMAIL=admin@o-ogo.ru
# Optional comma-separated extra names, for example: www.o-ogo.ru
CERTBOT_EXTRA_DOMAINS=
# Set true on VPS to test Let's Encrypt validation without saving a certificate.
CERTBOT_DRY_RUN=false
# Set true only if you want to install a non-trusted Let's Encrypt staging certificate.
CERTBOT_STAGING=false
OTZIV_APP_BASE_URL=https://o-ogo.ru
KEYCLOAK_PUBLIC_URL=https://o-ogo.ru/keycloak

APP_IMAGE=claid38/otziv-app:latest
WEB_IMAGE=claid38/otziv-web:latest

MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
DATABASE_URL=jdbc:mysql://mysql:3306/otziv
MYSQL_DATABASE=otziv
MYSQL_USER=hunt
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_KEYCLOAK_DB_PASSWORD
KEYCLOAK_ADMIN=hunt
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
KEYCLOAK_ADMIN_REALM=otziv
KEYCLOAK_ADMIN_CLIENT_ID=otziv-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_ADMIN_CLIENT_SECRET
KEYCLOAK_AUDIENCE=otziv-backend
KEYCLOAK_ISSUER_URI=https://o-ogo.ru/keycloak/realms/otziv
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/keycloak/realms/otziv/protocol/openid-connect/certs
KEYCLOAK_ADMIN_SERVER_URL=http://keycloak:8080/keycloak
KC_PROXY_TRUSTED_ADDRESSES=172.16.0.0/12,127.0.0.0/8

SESSION_TIMEOUT=30m
JAVA_OPTS=-Xms256m -Xmx768m -XX:MaxRAMPercentage=75
OTZIV_LOG_PATH=/app/logs
OTZIV_CABINET_CACHE_TTL=PT3H
OTZIV_SLOW_SQL_MS=250

MAIL_HOST=smtp.mail.selcloud.ru
MAIL_PORT=1126
MAIL_USERNAME=CHANGE_ME_MAIL_USERNAME
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_STARTTLS_ENABLE=true

TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_TOKEN
TELEGRAM_BOT_USERNAME=CHANGE_ME_TELEGRAM_BOT_USERNAME

S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_ENDPOINT=https://s3.ru-7.storage.selcloud.ru
S3_REGION=ru-7
S3_BUCKET=review-photos
S3_PROJECT=CHANGE_ME_S3_PROJECT

OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_PROXY_HOST=
OPENAI_PROXY_PORT=8888

# HS256 sync token secret, at least 32 bytes. Use 64+ random characters.
JWT_SECRET=CHANGE_ME_64_PLUS_RANDOM_CHARS

LEAD_TRANSFER_URL=https://o-ogo.ru/api/leads/import
LEAD_SYNCHRONY_URL=https://o-ogo.ru/api/leads/modified
LEAD_UPDATE_URL=https://o-ogo.ru/api/leads/update
LEAD_VPS_URL=https://o-ogo.ru/api/leads/sync
LEAD_SYNC_OUTBOUND_ENABLED=false
LEAD_VPS_RETRY_BATCH_SIZE=100
LEAD_VPS_RETRY_MAX_ATTEMPTS=20
LEAD_VPS_RETRY_PERIOD_MS=1800000

APP_NAGUL_COOLDOWN=60
MULTIBROWSER_BASE_URL=http://multi-browser:3000

BACKUP_ENABLED=true
BACKUP_WORK_DIR=/app/backup
BACKUP_MYSQL_HOST=mysql
BACKUP_MYSQL_PORT=3306
BACKUP_MYSQL_DUMP_BINARY=mysqldump
BACKUP_PART_SIZE_MB=35
BACKUP_MAIL_TO=2.12nps@mail.ru
BACKUP_MAIL_FROM=o-ogo.ru
BACKUP_MAIL_SUBJECT=Otziv database backup
BACKUP_MAIL_BODY=Daily database backup

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
